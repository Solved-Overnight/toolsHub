rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read and write access to the 'recipes' collection for authenticated users
    match /recipes/{recipeId} {
      allow read, write: if request.auth != null;
    }

    // If you have other collections, you'll need to add rules for them here.
    // For example, to allow read-only access to a 'public_data' collection:
    // match /public_data/{document=**} {
    //   allow read: if true;
    // }
  }
}
